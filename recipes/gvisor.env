# recipes/gvisor.env
# 範例：google/gvisor
# gvisor 用 bazel build，從源碼自己 build 很重（需要 bazel + 大量資源）。
# 官方提供現成的 runsc .deb，但只透過 apt repo 散布，沒有 ".../latest/runsc.deb"
# 這種固定單檔連結。真正的 .deb 在 repo 的 pool/ 下、以版本(日期)命名。
# 因此最務實的做法是用 url 模式直接抓 pool 內的版本化 deb。
#
# 下面這個 URL 已實測可下載（HTTP 200、application/vnd.debian.binary-package）。
# 換新版方法：抓 apt repo 的 Packages 索引，讀其中的 Filename 欄位 ——
#   curl -s https://storage.googleapis.com/gvisor/releases/dists/release/main/binary-amd64/Packages
#   # 例如 Filename: pool/20260608.0/binary-amd64/runsc.deb
# arm64 把上面索引網址與下面 URL 的 binary-amd64 改成 binary-arm64。

export MODE="url"
export DEB_URLS="https://storage.googleapis.com/gvisor/releases/pool/20260608.0/binary-amd64/runsc.deb"

# --- 如果一定要從源碼 build（需要 bazel，較重），可改用以下設定 ---
# export MODE="go"
# export SOURCE_REPO="google/gvisor"
# export APT_BUILD_DEPS="build-essential"
# export BUILD_CMD="make copy TARGETS=runsc DESTINATION=bin/"
# export BIN_PATHS="bin/runsc=/usr/bin/runsc"
# export PKG_NAME="runsc"
