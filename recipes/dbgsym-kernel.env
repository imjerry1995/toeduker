# recipes/dbgsym-kernel.env
# 範例：對應你原本 linux-dbgsym-crash 的用法。
# 從 ddebs.ubuntu.com 直接抓現成的 kernel dbgsym .deb 放進 image 等待掃描。
#
# 直接在 workflow inputs 填 deb_urls 也可以；這個 recipe 只是把常用前綴記下來方便改。
# 範例 URL（請依需要的 kernel 版本替換）：

export MODE="url"
export DEB_URLS="http://ddebs.ubuntu.com/pool/main/l/linux-hwe-6.17/linux-image-unsigned-6.17.0-20-generic-dbgsym_6.17.0-20.24.04_amd64.ddeb"

# 註：ddebs 的 dbgsym 副檔名常是 .ddeb；build_url.sh 下載後會自動把 .ddeb
# 改名成 .deb，因此 Dockerfile.image 的 COPY out/*.deb 能正常收集到，無需額外處理。
