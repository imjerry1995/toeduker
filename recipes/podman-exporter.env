# recipes/podman-exporter.env
# 範例：containers/prometheus-podman-exporter（Go + CGO，依賴 libpod 相關 dev 套件）
# 用法：workflow inputs 只要填 recipe=podman-exporter

export MODE="go"
export SOURCE_REPO="containers/prometheus-podman-exporter"
export GO_VERSION="1.22.5"

# podman-exporter 用到 libpod，CGO 預設開啟，需要這些系統 header。
# libsystemd-dev / libbtrfs-dev 對應 Makefile 的 systemd_tag.sh / btrfs_tag.sh，
# 缺了不會 build 失敗，但會少掉對應的 build tag 功能。
export APT_BUILD_DEPS="libbtrfs-dev libgpgme-dev libdevmapper-dev libsystemd-dev pkg-config gcc"

# 已查證 upstream Makefile：binary target 會輸出到 ./bin/prometheus-podman-exporter。
# （此 repo 沒有 build target，故不要用 "make binary || make build" 當 fallback。）
export BUILD_CMD="make binary"
export BIN_PATHS="bin/prometheus-podman-exporter=/usr/bin/prometheus-podman-exporter"

export PKG_NAME="prometheus-podman-exporter"
export PKG_DEPENDS="libgpgme11,libdevmapper1.02.1"
